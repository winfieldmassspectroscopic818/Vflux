{
  "name": "vflux",
  "version": "0.9.0",
  "author": "Vflux contributors",
  "description": "Vflux - 面向 FPGA 学习与开发的图形化工具，配合 OSS CAD Suite 使用",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "validate:examples": "node scripts/validate-examples.js",
    "release:check": "npm run validate:examples",
    "pack:win": "npm run release:check && electron-builder --win portable --config.win.signAndEditExecutable=false",
    "pack:win:zip": "npm run release:check && electron-builder --win zip --config.win.signAndEditExecutable=false",
    "pack:linux": "npm run release:check && electron-builder --linux AppImage",
    "build": "npm run pack:win"
  },
  "build": {
    "appId": "com.vflux.app",
    "productName": "Vflux",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "renderer/**/*",
      "assets/**/*",
      "boards/**/*",
      "examples/**/*",
      "docs/**/*",
      "README*.md",
      "scripts/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "category": "Development",
      "icon": "assets/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}
