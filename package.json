{
  "name": "vflux",
  "version": "1.0.0",
  "author": "Vflux contributors",
  "description": "Vflux - a graphical FPGA workflow tool for OSS CAD Suite",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "validate:examples": "node scripts/validate-examples.js",
    "release:check": "npm run validate:examples",
    "pack:win": "npm run release:check && electron-builder --win portable --config.win.signAndEditExecutable=false --config.artifactName=Vflux-Windows-${version}.${ext}",
    "pack:win:1.0.0": "npm run pack:win",
    "pack:win:zip": "npm run release:check && electron-builder --win zip --config.win.signAndEditExecutable=false --config.artifactName=Vflux-Windows-${version}.${ext}",
    "pack:linux": "npm run release:check && electron-builder --linux AppImage --config.extraMetadata.version=0.9.1 --config.artifactName=Vflux-Linux-0.9.1.${ext}",
    "pack:linux:0.9.1": "npm run pack:linux",
    "build": "npm run pack:win"
  },
  "build": {
    "appId": "com.vflux.app",
    "productName": "Vflux",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "renderer/**/*",
      "assets/**/*",
      "boards/**/*",
      "examples/**/*",
      "docs/**/*",
      "README*.md",
      "scripts/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "category": "Development",
      "icon": "assets/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}
